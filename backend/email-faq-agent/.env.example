# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Email Agent

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EMAIL_TOPIC=email-jobs
KAFKA_DEAD_LETTER_TOPIC=email-jobs-dlq
KAFKA_CONSUMER_GROUP=email-agent-group

# Agent
MAX_RETRIES=3
AUTO_QUEUE_THRESHOLD_BYTES=1024

# App
LOG_LEVEL=INFO
APP_ENV=development

# Gemini
GEMINI_API_KEY=your-gemini-api-key
